{
  "mcpServers": {
    "user-openspec": {
      "command": "npx",
      "args": ["-y", "openspec-mcp", "--with-dashboard"]
    },
    "user-n8n": {
      "command": "npx",
      "args": ["-y", "n8n-mcp"],
      "env": {
        "N8N_API_URL": "http://localhost:5678",
        "N8N_API_KEY": "TU_N8N_API_KEY_AQUI"
      }
    }
  }
}
