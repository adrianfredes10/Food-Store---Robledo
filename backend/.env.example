# Copiar a `.env` y ajustar valores. Alembic y la app leen `backend/.env`.

# --- Base de datos (obligatorio) ---
# PostgreSQL (entrega / producción). Crear DB y usuario antes de `alembic upgrade head`.
DATABASE_URL=postgresql+psycopg2://foodstore:foodstore@127.0.0.1:5432/foodstore

# SQLite solo desarrollo local (create_all en bootstrap; Alembic también funciona):
# DATABASE_URL=sqlite:///./foodstore.db

# --- JWT / sesión ---
JWT_SECRET_KEY=cambiar-por-secreto-largo-y-aleatorio-minimo-32-caracteres
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Orígenes CORS separados por coma (sin espacios o con espacios recortados)
CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173

# --- Mercado Pago (backend) ---
# Access Token: panel de desarrolladores → tu aplicación → Credenciales (prueba o producción).
MERCADOPAGO_ACCESS_TOKEN=
# true = mock local sin llamar a MP. false = API real (requiere MERCADOPAGO_ACCESS_TOKEN).
MERCADOPAGO_MOCK=true
# Debe coincidir con la URL donde corre la API (webhooks / back_urls de Checkout Pro).
PUBLIC_APP_URL=http://127.0.0.1:8008

# --- Imagen automática de productos (Groq LLM → prompt en inglés + URL pública Pollinations) ---
# Sin imagen_url en el POST: si PRODUCTO_IMAGEN_AUTO=true y GROQ_API_KEY está definida, el backend
# completa `imagen_url` en segundo plano (varios segundos). La descripción del producto alimenta el prompt.
GROQ_API_KEY=
# Opcional; si Groq responde 400 por modelo deprecado, actualizá en panel Groq / docs.
# GROQ_MODEL=llama-3.3-70b-versatile
PRODUCTO_IMAGEN_AUTO=false

# --- Depuración ---
# DEBUG=true

# --- Rate limit login (slowapi, por IP; cada POST /auth/login cuenta, también si es exitoso) ---
# Por defecto en código: "60 per 15 minutes". En producción podés bajar (p. ej. "10 per 15 minutes").
# LOGIN_RATE_LIMIT=60 per 15 minutes
# Desarrollo: desactivar por completo (no usar en producción expuesta).
# DISABLE_LOGIN_RATE_LIMIT=1
